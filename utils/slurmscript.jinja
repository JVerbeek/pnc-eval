#!/bin/bash
#SBATCH --partition=das
#SBATCH --qos=das-small
#SBATCH --cpus-per-task= {{ n_cpu }}
#SBATCH --mem=10G
#SBATCH --gres=gpu:1
#SBATCH --time= {{ time }}
#SBATCH --output=%A_%a.out
#SBATCH --error=%A-%a.err
#SBATCH --array={{arr_lo}}-{{ arr_hi}}


config={{ config }}

model=$(awk -v ArrayTaskID=$SLURM_ARRAY_TASK_ID '$1==ArrayTaskID {print $2}' $config)
generator=$(awk -v ArrayTaskID=$SLURM_ARRAY_TASK_ID '$1==ArrayTaskID {print $3}' $config)

python3 evaluate_model_on_generator.py --generator-hyperparameters generator --model-hyperparameters model